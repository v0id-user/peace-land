---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const { title } = Astro.props;
const pageTitle = title ? `${title} — #V0ID` : '#V0ID';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="brand-row">
          <a href="https://github.com/v0id-user" target="_blank" rel="noopener"><img src="https://avatars.githubusercontent.com/u/172490913?v=4" alt="" width="24" height="24" class="avatar" /></a>
          <a href="/" class="brand">#V0ID</a>
        </div>
        <iframe src="/now-playing" class="np-frame" frameborder="0" scrolling="no"></iframe>
        <nav>
          {posts.map((post) => (
            <a
              href={`/posts/${post.data.slug}`}
              class={Astro.url.pathname.includes(post.data.slug) ? 'active' : ''}
            >
              {post.data.title.length > 24 ? post.data.title.slice(0, 22) + '..' : post.data.title}
            </a>
          ))}
          <a href="/about" class={Astro.url.pathname.startsWith('/about') ? 'active' : ''} style="margin-top: 6px;">about</a>
          <a href="/tree" class={Astro.url.pathname.startsWith('/tree') ? 'active' : ''}>tree</a>
          <a href="/pgp" class={Astro.url.pathname.startsWith('/pgp') ? 'active' : ''}>pgp</a>
          <a href="/human" class={Astro.url.pathname.startsWith('/human') ? 'active' : ''} style="margin-top: 6px;">human</a>
          <a href="/test" class={Astro.url.pathname.startsWith('/test') ? 'active' : ''} style="margin-top: 16px;">tests</a>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
