---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  noindex?: boolean;
}

const { title, description, type = 'website', publishedDate, noindex = false } = Astro.props;
const pageTitle = title ? `${title} — #V0ID` : '#V0ID';
const metaDescription = description || 'Technical blog by #V0ID — backend engineering, Rust, TypeScript, Cloudflare, and systems programming.';
const canonicalURL = new URL(Astro.url.pathname, 'https://www.v0id.me');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="#V0ID" />
    <meta property="og:locale" content="en_US" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:site" content="@v0id_user" />
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="brand-row">
          <a href="https://github.com/v0id-user" target="_blank" rel="noopener" aria-label="GitHub profile"><img src="https://avatars.githubusercontent.com/u/172490913?v=4" alt="GitHub avatar" width="24" height="24" class="avatar" /></a>
          <a href="/" class="brand">#V0ID</a>
        </div>
        <iframe
          src="/now-playing"
          class="np-frame"
          title="Now playing on Spotify"
        ></iframe>
        <nav>
          {posts.map((post) => (
            <a
              href={`/posts/${post.data.slug}`}
              class={Astro.url.pathname.includes(post.data.slug) ? 'active' : ''}
            >
              {post.data.title.length > 24 ? post.data.title.slice(0, 22) + '..' : post.data.title}
            </a>
          ))}
          <a href="/about" class={Astro.url.pathname.startsWith('/about') ? 'active' : ''} style="margin-top: 6px;">about</a>
          <a href="/tree" class={Astro.url.pathname.startsWith('/tree') ? 'active' : ''}>tree</a>
          <a href="/pgp" class={Astro.url.pathname.startsWith('/pgp') ? 'active' : ''}>pgp</a>
          <a href="/human" class={Astro.url.pathname.startsWith('/human') ? 'active' : ''} style="margin-top: 6px;">human</a>
          <a href="/test" class={Astro.url.pathname.startsWith('/test') ? 'active' : ''} style="margin-top: 16px;">tests</a>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
