---
import Base from '../layouts/Base.astro';
import { PGP_PUBLIC_KEY_ARMORED } from '../lib/pgpKey';
---

<Base title="PGP">
  <div class="tree-page">
    <h1>PGP</h1>
    <p class="tree-note">
      #V0ID &lt;hey@v0id.me&gt;, signing key. Fingerprint 6BEC 93C9 0963 3B56 534E 2DCE 1F4F 0EDA 6419 E19.
    </p>
    <p class="tree-note">
      Raw: <a href="https://pgp.v0id.me">pgp.v0id.me</a> · <a href="https://gpg.v0id.me">gpg.v0id.me</a>
    </p>
    <pre class="pgp-key">{PGP_PUBLIC_KEY_ARMORED}</pre>
  </div>
</Base>
