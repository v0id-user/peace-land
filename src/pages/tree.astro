---
import Base from '../layouts/Base.astro';

const links = [
  { name: 'GitHub', url: 'https://github.com/v0id-user' },
  { name: 'X (Twitter)', url: 'https://x.com/v0id_user', inactive: true },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/v0id-user' },
  { name: 'Bluesky', url: 'https://bsky.app/profile/v0id.me', inactive: true },
  { name: 'Reddit', url: 'https://reddit.com/u/v0id_user', inactive: true },
  { name: 'Instagram', url: 'https://instagram.com/v0id_user', inactive: true },
  { name: 'Email', url: 'mailto:hey@v0id.me' },
  { name: 'PGP key', url: 'https://pgp.v0id.me' },
  { name: 'Book a Call', url: 'https://cal.com/v0id-user/30min' },
];
---

<Base title="Tree" description="Links and social profiles for #V0ID — GitHub, X, LinkedIn, email, and more.">
  <div class="tree-page">
    <h1>Links</h1>
    <ul class="tree-links">
      {links.map((link) => (
        <li class:list={[{ 'tree-links-item--inactive': link.inactive }]}>
          <a href={link.url} target="_blank" rel="noopener">{link.name}</a>
          {link.inactive && (
            <span class="tree-links-status"> (inactive/archived)</span>
          )}
        </li>
      ))}
    </ul>
    <p class="tree-note">
      I’m not very active on socials—replies there are slow.<br />
      Email is the best way to reach me.<br />
      LinkedIn messages are fine too.
    </p>
  </div>
</Base>
