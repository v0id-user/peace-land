---
export const prerender = false;
import { getNowPlaying } from '../lib/spotify';
import { env as cfEnv } from 'cloudflare:workers';

const mergedEnv = { ...import.meta.env, ...cfEnv };
const np = await getNowPlaying(mergedEnv);
const pct = (np.duration_ms && np.progress_ms) ? (np.progress_ms / np.duration_ms * 100) : 0;
const remainSec = (np.duration_ms && np.progress_ms) ? Math.round((np.duration_ms - np.progress_ms) / 1000) : 0;
const hasTrack = !!np.title;
const fullText = hasTrack ? `${np.title} — ${np.artist}` : '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="30" />
    <style>
      * { margin: 0; padding: 0; }
      body {
        font-family: Verdana, Geneva, sans-serif;
        font-size: 9px;
        color: #555;
        background: #fff;
        overflow: hidden;
      }
      a { color: inherit; text-decoration: none; }
      .np { padding: 2px 0; }
      .np-track {
        display: flex;
        align-items: flex-start;
        gap: 4px;
      }
      .np-icon { flex-shrink: 0; margin-top: 1px; }
      .np-info { min-width: 0; overflow: hidden; position: relative; }
      .np-title {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: bold;
        color: #000;
      }
      .np-artist {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #555;
      }
      .np-bar { height: 2px; background: #ddd; margin-top: 3px; }
      .np-fill { height: 100%; background: #000; }
      .np-fill.playing { animation: progress linear forwards; }
      @keyframes progress { to { width: 100%; } }
      .np-idle { color: #999; font-style: italic; }
      .np-label {
        display: block;
        font-style: italic;
        color: #999;
        font-size: 8px;
        margin-top: 2px;
      }
      .pause-label {
        color: #999;
        font-size: 8px;
        margin-right: 3px;
      }
    </style>
  </head>
  <body>
    <div class="np">
      <div class="np-track">
        <img src="/spotify-pixle-logo-black.svg" alt="" width="12" height="12" class="np-icon" />
        {hasTrack ? (
          <div class="np-info">
            <a href={np.url} target="_blank" rel="noopener" title={`${np.title} — ${np.artist}`}>
              <span class="np-title">
                {!np.is_playing && <span class="pause-label">paused</span>}{np.title}
              </span>
              <span class="np-artist">{np.artist}</span>
            </a>
            <div class="np-bar">
              <div
                class:list={["np-fill", { playing: np.is_playing }]}
                style={np.is_playing ? `width:${pct}%;animation-duration:${remainSec}s` : `width:${pct}%`}
              ></div>
            </div>
          </div>
        ) : (
          <span class="np-idle">silence.</span>
        )}
      </div>
      <span class="np-label">currently listening to...</span>
    </div>
  </body>
</html>
